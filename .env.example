# Server
PORT=3000
NODE_ENV=development

# Only this frontend origin may call the API from a browser.
FRONTEND_ORIGIN=http://localhost:3000

# Business inbox that receives contact form messages.
CONTACT_TO=info@bln-security-solutions.de

# Verified sender address from your email provider.
CONTACT_FROM=website@bln-security-solutions.de

# SMTP settings from your email provider.
# Never commit your real SMTP password to git.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
